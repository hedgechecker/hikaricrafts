// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Review {
  id      Int    @id @default(autoincrement())
  rating  Int
  comment String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user   User @relation(fields: [userId], references: [id])
  userId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  @@unique([userId, productId]) // prevents multiple reviews for same product
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  series      String  @default("") 
  warranty    String  @default("") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  options    ProductOption[]
  variations ProductVariation[]
  reviews    Review[]
}

model ProductOption {
  id        Int    @id @default(autoincrement())
  productId Int
  name      String // e.g. "Wood", "Finish", "Engraving"

  product Product              @relation(fields: [productId], references: [id])
  values  ProductOptionValue[]
}

model ProductOptionValue {
  id       Int    @id @default(autoincrement())
  optionId Int
  value    String // e.g. "Oak", "Walnut", "Oiled", "Engraving Text"

  option     ProductOption                 @relation(fields: [optionId], references: [id])
  variations ProductVariationOptionValue[]
}

model ProductVariation {
  id         Int    @id @default(autoincrement())
  productId  Int
  sku        String @unique
  priceCents Int
  stock      Int

  height      Int?
  width       Int?
  depth       Int?
  weightGrams Int?

  product      Product                       @relation(fields: [productId], references: [id])
  optionValues ProductVariationOptionValue[]
  orderItems   OrderItem[]
  images       Image[]
}

model ProductVariationOptionValue {
  id            Int @id @default(autoincrement())
  variationId   Int
  optionValueId Int

  variation   ProductVariation   @relation(fields: [variationId], references: [id])
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id])
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  variationId   Int
  quantity      Int
  engravingText String? // customer input
  // + price snapshot etc.

  variation ProductVariation @relation(fields: [variationId], references: [id])
}

model Image {
   id                   Int     @id @default(autoincrement())
   path                 String  
   alt                  String
   productVariationId   Int
   variation   ProductVariation   @relation(fields: [productVariationId], references: [id])
}

enum Role {
  USER
  ADMIN
}

model Feedback {
  id        Int      @id @default(autoincrement())
  message   String
  rating    String?
  createdAt DateTime @default(now())
}
